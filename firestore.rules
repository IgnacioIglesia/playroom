rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rankings — anyone can read, only authenticated users can write their own entries
    match /ranking_truco/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    match /ranking_sudoku/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    match /ranking_buscaminas/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    // Palabras ranking — can update (for streak) but only own doc
    match /ranking_palabras/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == request.resource.data.uid;
    }

    // User profiles — public read, only own user can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Match history — private to the owner
    match /users/{userId}/historial/{matchId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
